# Canonical site URL (no trailing slash) — used for Open Graph metadata.
# Local dev: http://localhost:3000
# Production (user site repo YOUR_USERNAME.github.io): https://YOUR_USERNAME.github.io
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: only when simulating a GitHub *project* site (repo name NOT *.github.io). See README.
# NEXT_PUBLIC_BASE_PATH=/repo-name

# Formspree form endpoint: https://formspree.io/f/{your_form_id}
NEXT_PUBLIC_FORMSPREE_FORM_ID=your_form_id_here

# Optional: Ask Ethan widget — HTTPS endpoint that accepts POST JSON { "message": "..." } and returns { "reply": "..." }.
# Scaffold lives in workers/ask-ethan (Cloudflare Worker). Deploy it, then set this URL at build time.
# See workers/ask-ethan/README.md. GitHub Pages cannot run API routes.
# NEXT_PUBLIC_ASK_ETHAN_API_URL=https://ask-ethan.YOUR_SUBDOMAIN.workers.dev

# Optional: visitor strip — JSON URL returning { "count": number } with CORS enabled (e.g. self-hosted counter).
# NEXT_PUBLIC_VISITOR_COUNTER_JSON=https://example.com/api/views.json
