# Canonical site URL (no trailing slash) — used for Open Graph metadata.
# Local dev: http://localhost:3000
# GitHub project site (repo "portfolio"): https://YOUR_USERNAME.github.io/portfolio
# GitHub user site (repo "YOUR_USERNAME.github.io"): https://YOUR_USERNAME.github.io
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Only when testing a GitHub *project* site build locally — must match next.config basePath (see README).
# NEXT_PUBLIC_BASE_PATH=/portfolio

# Formspree form endpoint: https://formspree.io/f/{your_form_id}
NEXT_PUBLIC_FORMSPREE_FORM_ID=your_form_id_here
